            }
          }
        },
        {
          "label": "Meditate before the tablet",
          "check": {
            "stat": "wis",
            "dc": 14
          },
          "success": {
            "text": "In deep meditation, the tablet's meaning washes over you. Full restoration and clarity of purpose.",
            "rewards": {
              "healPct": 100,
              "manaPct": 100,
              "xp": 50
            }
          },
          "failure": {
            "text": "The wind disrupts your focus. You gather yourself and move on, humbled.",
            "rewards": {
              "xp": 15
            }
          }
        }
      ]
    },
