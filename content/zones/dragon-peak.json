  "events": [
    {
      "slug": "volcanic-vent",
      "name": "Volcanic Vent",
      "type": "environmental",
      "rarity": "common",
      "icon": "\ud83c\udf0b",
      "text": "Steam and sulfurous gas hiss from a crack in the mountainside. The heat is intense, but you notice something glinting in the vent.",
      "choices": [
        {
          "label": "Reach into the vent carefully",
          "check": {
            "stat": "dex",
            "dc": 14
          },
          "success": {
            "text": "You snatch a chunk of crystallized fire mineral from the vent before the heat becomes unbearable.",
            "rewards": {
              "items": [
                {
                  "slug": "iron-ore",
                  "qty": 3
                }
              ],
              "gold": 30,
              "xp": 30
            }
          },
          "failure": {
            "text": "The vent erupts as you reach in! Burns sear your arm.",
            "rewards": {
              "xp": 12,
              "damage": 25
            }
          }
        },
        {
          "label": "Study the vent from a safe distance",
          "check": {
            "stat": "int",
            "dc": 12
          },
          "success": {
            "text": "You identify the mineral deposits and note their position. The geological knowledge is valuable.",
            "rewards": {
              "xp": 35
            }
          },
          "failure": {
            "text": "A sudden gust of superheated air singes your eyebrows. Nature is not to be trifled with.",
            "rewards": {
              "xp": 12
            }
          }
        }
      ]
    },
    {
      "slug": "dragon-scale-find",
      "name": "Shed Dragon Scale",
      "type": "discovery",
      "rarity": "uncommon",
      "icon": "\ud83d\udc09",
      "text": "A massive scale, shed from a dragon, lies wedged between rocks. It shimmers with residual draconic energy.",
      "choices": [
        {
          "label": "Pry the scale free",
          "check": {
            "stat": "str",
            "dc": 13
          },
          "success": {
            "text": "With tremendous effort you wrench the scale loose. It's heavier than expected but incredibly valuable.",
            "rewards": {
              "gold": 50,
              "xp": 30
            }
          },
          "failure": {
            "text": "The scale won't budge. You strain until your muscles burn, then give up.",
            "rewards": {
              "xp": 12
            }
          }
        },
        {
          "label": "Examine the scale for arcane properties",
          "check": {
            "stat": "int",
            "dc": 13
          },
          "success": {
            "text": "The scale pulses with residual fire magic. Studying it teaches you about draconic enchantments.",
            "rewards": {
              "xp": 45
            }
          },
          "failure": {
            "text": "The magic is too alien for you to decipher. Beautiful but incomprehensible.",
            "rewards": {
              "xp": 12
            }
          }
        }
      ]
    },
    {
      "slug": "ancient-dragon-lore",
      "name": "Dragon Lore Tablet",
      "type": "discovery",
      "rarity": "rare",
      "icon": "\ud83d\udcd6",
      "text": "A stone tablet carved in draconic script stands at the mountain's highest reachable point. The wind howls around it, carrying whispers of power.",
      "choices": [
        {
          "label": "Decipher the draconic script",
          "check": {
            "stat": "int",
            "dc": 15
          },
          "success": {
            "text": "The tablet reveals secrets of dragon magic. Ancient power surges through your veins as understanding dawns.",
            "rewards": {
              "xp": 60,
              "manaPct": 100
            }
          },
          "failure": {
            "text": "The script is beyond your current knowledge. Perhaps with more experience...",
            "rewards": {
