        {
          "label": "Challenge the guardian to a test of will",
          "check": {
            "stat": "wis",
            "dc": 13
          },
          "success": {
            "text": "Your willpower impresses the spirit. It bows and bestows a blessing of restoration.",
            "rewards": {
              "healPct": 40,
              "manaPct": 60,
              "xp": 35
            }
          },
          "failure": {
            "text": "The guardian's presence overwhelms you. You retreat, shaken.",
            "rewards": {
              "xp": 10,
              "damage": 15
            }
          }
        }
      ]
