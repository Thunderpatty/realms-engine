  "events": [
    {
      "slug": "enchanted-mirror",
      "name": "Enchanted Mirror",
      "type": "puzzle",
      "rarity": "uncommon",
      "icon": "\ud83e\ude9e",
      "text": "A tall mirror stands in an alcove, its surface swirling with purple mist. Your reflection moves independently, mimicking you with a mocking grin.",
      "choices": [
        {
          "label": "Touch the mirror's surface",
          "check": {
            "stat": "int",
            "dc": 13
          },
          "success": {
            "text": "You feel arcane energy flow through you as the mirror absorbs negative energy. Your mind feels sharper.",
            "rewards": {
              "manaPct": 50,
              "xp": 30
            }
          },
          "failure": {
            "text": "The mirror lashes out with psychic energy! Your reflection laughs silently.",
            "rewards": {
              "xp": 10,
              "damage": 20
            }
          }
        },
        {
          "label": "Smash the mirror",
          "check": {
            "stat": "str",
            "dc": 11
          },
          "success": {
            "text": "The glass shatters and shadow ichor pools from the frame. You collect what you can.",
            "rewards": {
              "items": [
                {
                  "slug": "shadow-ichor",
                  "qty": 2
                }
              ],
              "xp": 20
            }
          },
          "failure": {
            "text": "The mirror absorbs your blow and redirects it. Your fist aches.",
            "rewards": {
              "xp": 8,
              "damage": 15
            }
          }
        },
        {
          "label": "Walk past without looking",
          "auto": true,
          "success": {
            "text": "You avert your gaze. Sometimes the best magic is restraint.",
            "rewards": {
              "xp": 5
            }
          }
        }
      ]
    },
    {
      "slug": "cursed-door",
      "name": "Warded Door",
      "type": "puzzle",
      "rarity": "common",
      "icon": "\ud83d\udeaa",
      "text": "A heavy door is etched with arcane wards that glow and pulse. It seems to be sealed by magic, but the ward is old and weakening.",
