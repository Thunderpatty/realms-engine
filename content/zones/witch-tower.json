              "items": [
                {
                  "slug": "shadow-ichor",
                  "qty": 1
                }
              ],
              "xp": 25
            }
          },
          "failure": {
            "text": "The ward fights back, sending a painful shock through your hands.",
            "rewards": {
              "xp": 10,
              "damage": 15
            }
          }
        },
        {
          "label": "Force it open physically",
          "check": {
            "stat": "str",
            "dc": 14
          },
          "success": {
            "text": "The hinges give way before the ward does. Inside you find gold and materials.",
            "rewards": {
              "gold": 30,
              "xp": 20
            }
          },
          "failure": {
            "text": "The door doesn't budge. The ward flares in response, burning your palms.",
            "rewards": {
              "xp": 8,
              "damage": 18
            }
          }
        }
      ]
    },
    {
      "slug": "spectral-guardian",
      "name": "Spectral Guardian",
      "type": "npc",
      "rarity": "rare",
      "icon": "\ud83d\udc41",
      "text": "A spectral figure blocks the corridor, glowing with ethereal light. \"Prove your worth, mortal, and I shall grant you passage and a boon.\"",
