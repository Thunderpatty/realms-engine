            "text": "You carefully break free a perfect crystal. It pulses with warmth."
          },
          "failure": {
            "damage": 15,
            "text": "The formation shatters! Shards cut into you."
          }
        },
        {
          "text": "Meditate near the crystals (INT DC 12)",
          "check": {
            "stat": "int",
            "dc": 12
          },
          "success": {
