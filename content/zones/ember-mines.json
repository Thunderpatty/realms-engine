      "name": "Crystal Formation",
      "icon": "\ud83d\udc8e",
      "description": "A stunning cluster of crystals juts from the wall, humming with energy.",
      "choices": [
        {
          "text": "Extract a crystal (STR DC 13)",
          "check": {
            "stat": "str",
            "dc": 13
          },
          "success": {
