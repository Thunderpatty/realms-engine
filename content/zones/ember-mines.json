  "events": [
    {
      "slug": "ore-vein",
      "name": "Rich Ore Vein",
      "type": "discovery",
      "rarity": "common",
      "icon": "\u26cf",
      "text": "A glistening vein of ore runs through the mine wall, catching the light of your torch. It looks richer than the usual deposits.",
      "choices": [
        {
          "label": "Mine the vein with careful strikes",
          "check": {
            "stat": "str",
            "dc": 11
          },
          "success": {
            "text": "Chunks of quality ore break free. This will fetch a good price or make fine equipment.",
            "rewards": {
              "items": [
                {
                  "slug": "iron-ore",
                  "qty": 4
                }
              ],
              "xp": 20
            }
          },
          "failure": {
            "text": "Your strikes are too forceful. The vein shatters, yielding only fragments.",
            "rewards": {
              "items": [
                {
                  "slug": "iron-ore",
                  "qty": 1
                }
              ],
              "xp": 8
            }
          }
        },
        {
          "label": "Examine the vein for rare minerals",
          "check": {
            "stat": "int",
            "dc": 13
          },
          "success": {
            "text": "You identify traces of a rare mineral mixed in with the ore. Careful extraction yields a find.",
            "rewards": {
              "items": [
                {
                  "slug": "iron-ore",
                  "qty": 2
                }
              ],
              "gold": 25,
              "xp": 25
            }
          },
          "failure": {
            "text": "It's just standard ore. Good, but nothing special.",
            "rewards": {
              "items": [
                {
                  "slug": "iron-ore",
                  "qty": 1
                }
              ],
              "xp": 8
            }
          }
        }
      ]
    },
    {
      "slug": "trapped-miner",
      "name": "Trapped Miner",
      "type": "npc",
      "rarity": "uncommon",
      "icon": "\ud83d\udc77",
      "text": "Muffled cries echo from behind a rockfall. A miner is trapped in a collapsed side tunnel, their lamp flickering weakly.",
      "choices": [
        {
          "label": "Clear the rubble to free them",
          "check": {
            "stat": "str",
            "dc": 12
          },
          "success": {
            "text": "Stone by stone you clear a path. The miner crawls out, grateful beyond words, pressing ore and coin into your hands.",
            "rewards": {
              "gold": 30,
              "items": [
                {
                  "slug": "iron-ore",
                  "qty": 3
                }
              ],
              "xp": 25
            }
          },
          "failure": {
            "text": "The rubble shifts dangerously. You manage a small gap but rocks bruise you in the process.",
            "rewards": {
              "gold": 10,
              "xp": 12,
              "damage": 12
            }
          }
        },
        {
          "label": "Look for another way around",
          "check": {
            "stat": "wis",
            "dc": 11
          },
          "success": {
            "text": "You find a narrow ventilation shaft and guide the miner out. They share their day's haul.",
            "rewards": {
              "items": [
                {
                  "slug": "iron-ore",
                  "qty": 2
                }
              ],
              "gold": 20,
              "xp": 20
            }
          },
          "failure": {
            "text": "The shaft is a dead end. You return and help from the front, but it takes all your energy.",
            "rewards": {
              "xp": 10
            }
          }
        }
      ]
    },
    {
      "slug": "unstable-tunnel",
      "name": "Unstable Tunnel",
      "type": "environmental",
      "rarity": "common",
      "icon": "\ud83d\udca5",
      "text": "Timber supports groan ominously ahead. The tunnel could collapse, but you can see mine cart tracks leading to a deeper section.",
      "choices": [
        {
          "label": "Rush through before it gives way",
          "check": {
            "stat": "dex",
            "dc": 12
          },
          "success": {
            "text": "You sprint through as dust rains down. Beyond, an untouched section of the mine yields good ore.",
            "rewards": {
              "items": [
                {
                  "slug": "iron-ore",
                  "qty": 3
                }
              ],
              "xp": 20
            }
          },
          "failure": {
            "text": "A beam clips your shoulder as the tunnel groans. You barely make it through.",
            "rewards": {
              "xp": 10,
              "damage": 16
            }
          }
        },
        {
          "label": "Reinforce the supports first",
          "check": {
            "stat": "str",
            "dc": 10
          },
          "success": {
            "text": "Bracing the timbers takes effort but the tunnel holds. You explore safely and find ember dust.",
            "rewards": {
              "gold": 20,
              "xp": 15
            }
          },
          "failure": {
            "text": "Despite your effort, a support snaps. You retreat as the section caves in.",
            "rewards": {
              "xp": 8
            }
          }
        }
      ]
    },
    {
      "slug": "em-lava-vent",
      "rarity": "common",
      "name": "Lava Vent",
      "icon": "\ud83c\udf0b",
      "description": "A crack in the floor glows orange. Heated air blasts upward, and something metallic glints within.",
      "choices": [
        {
          "text": "Reach for the metal (DEX DC 12)",
          "check": {
            "stat": "dex",
            "dc": 12
          },
          "success": {
            "gold": 22,
            "text": "You snatch a chunk of raw ore before the heat drives you back. Valuable!"
          },
          "failure": {
            "damage": 12,
            "text": "The heat is too intense \u2014 you burn your hand badly!"
          }
        },
        {
          "text": "Use the heat to warm yourself",
          "success": {
            "heal": 8,
            "text": "The warmth soothes your aching muscles."
          }
        }
      ]
    },
    {
      "slug": "em-miners-ghost",
      "rarity": "uncommon",
      "name": "Miner's Ghost",
      "icon": "\ud83d\udc7b",
      "description": "A translucent figure in a hardhat gestures frantically, pointing deeper into the mines.",
      "choices": [
        {
          "text": "Follow the ghost (WIS DC 11)",
          "check": {
            "stat": "wis",
            "dc": 11
          },
          "success": {
            "gold": 28,
            "xp": 15,
            "text": "It leads you to a hidden vein of precious ore and a forgotten tool cache."
          },
          "failure": {
            "damage": 10,
            "text": "The ghost leads you into a dead end \u2014 then the ceiling creaks ominously!"
          }
        },
        {
          "text": "Ignore it",
          "success": {
            "text": "You've learned not to follow ghosts. Smart."
          }
        }
      ]
    },
    {
      "slug": "em-crystal-formation",
