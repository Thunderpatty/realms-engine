    {
      "slug": "merchant-caravan",
      "name": "Merchant Caravan",
      "type": "merchant",
      "rarity": "common",
      "icon": "\ud83d\udc34",
      "text": "A merchant caravan has stopped to repair a broken wheel. The lead merchant eyes you with interest \u2014 perhaps you can be of assistance.",
      "choices": [
        {
          "label": "Help repair the wheel",
          "check": {
            "stat": "str",
            "dc": 10
          },
          "success": {
            "text": "With your help the wheel is fixed in no time. The grateful merchant offers you supplies and coin.",
            "rewards": {
              "gold": 30,
              "items": [
                {
                  "slug": "health-potion",
                  "qty": 1
                }
              ],
              "xp": 15
            }
          },
          "failure": {
            "text": "The wheel snaps further. The merchant sighs but tosses you a coin for trying.",
            "rewards": {
              "gold": 5,
              "xp": 8
            }
          }
        },
        {
          "label": "Offer to guard them for a fee",
          "check": {
            "stat": "cha",
            "dc": 11
          },
          "success": {
            "text": "The merchant agrees. You escort them down the road and collect your payment.",
            "rewards": {
              "gold": 40,
              "xp": 20
            }
          },
          "failure": {
            "text": "\"We have our own guards, thanks.\" The merchant waves you off.",
            "rewards": {
              "xp": 5
            }
          }
        },
        {
          "label": "Continue on your way",
          "auto": true,
          "success": {
            "text": "You nod politely and continue down the dusty road.",
            "rewards": {
              "xp": 3
            }
          }
        }
      ]
    },
    {
      "slug": "roadside-shrine",
      "name": "Wayside Shrine",
