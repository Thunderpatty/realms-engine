  "events": [
    {
      "slug": "bog-lights",
      "name": "Dancing Bog Lights",
      "type": "environmental",
      "rarity": "common",
      "icon": "\ud83d\udca1",
      "text": "Eerie lights dance across the murky water, beckoning you deeper into the swamp. The air is thick with the scent of decay.",
      "choices": [
        {
          "label": "Follow the lights carefully",
          "check": {
            "stat": "wis",
            "dc": 12
          },
          "success": {
            "text": "The lights lead to a dry mound where rare shadow ichor has pooled in natural basins.",
            "rewards": {
              "items": [
                {
                  "slug": "shadow-ichor",
                  "qty": 2
                }
              ],
              "xp": 20
            }
          },
          "failure": {
            "text": "You stumble into a sinkhole! Murky water fills your boots as you scramble out, coughing.",
            "rewards": {
              "xp": 8,
              "damage": 15
            }
          }
        },
        {
          "label": "Avoid them and search the banks instead",
          "check": {
            "stat": "dex",
            "dc": 10
          },
          "success": {
            "text": "Along the bank you find serpent fangs and useful herbs among the reeds.",
            "rewards": {
              "items": [
                {
                  "slug": "serpent-fang",
                  "qty": 2
                }
              ],
              "xp": 15
            }
          },
          "failure": {
            "text": "The mud is treacherous. You slip and lose your footing, barely avoiding the swamp.",
            "rewards": {
              "xp": 5
            }
          }
        }
      ]
    },
    {
      "slug": "sunken-ruin",
      "name": "Sunken Ruin",
      "type": "discovery",
      "rarity": "uncommon",
      "icon": "\ud83c\udfda",
      "text": "Stone pillars rise from the muck \u2014 the remnants of a structure swallowed by the swamp centuries ago. Something glints beneath the murky water.",
      "choices": [
        {
          "label": "Dive into the murky water to investigate",
          "check": {
            "stat": "con",
            "dc": 13
          },
          "success": {
            "text": "You endure the foul water and pull up a corroded chest with gold and shadow ichor inside.",
            "rewards": {
              "gold": 40,
              "items": [
                {
                  "slug": "shadow-ichor",
                  "qty": 1
                }
              ],
              "xp": 25
            }
          },
          "failure": {
            "text": "The cold saps your strength. You surface gasping, with only a mouthful of swamp water for your trouble.",
            "rewards": {
              "xp": 10,
              "damage": 20
            }
          }
        },
        {
          "label": "Study the ruins from the bank",
          "check": {
            "stat": "int",
            "dc": 11
          },
          "success": {
            "text": "The inscriptions reveal this was a shadow mage's sanctum. You learn from the ancient writings.",
            "rewards": {
              "xp": 30
            }
          },
          "failure": {
            "text": "The inscriptions are too weathered. Only fragments remain legible.",
            "rewards": {
              "xp": 10
            }
          }
        }
      ]
    },
