  "events": [
    {
      "slug": "goblin-trader",
      "name": "Goblin Merchant",
      "type": "merchant",
      "rarity": "uncommon",
      "icon": "\ud83d\udc7a",
      "text": "A goblin sits behind a makeshift stall of bones and rope, wares spread on a filthy blanket. \"Trade? Trade! Good stuff, shiny stuff!\" it chatters.",
      "choices": [
        {
          "label": "Barter with the goblin",
          "check": {
            "stat": "cha",
            "dc": 11
          },
          "success": {
            "text": "After animated haggling, you trade stories for supplies. The goblin seems delighted.",
            "rewards": {
              "gold": 20,
              "items": [
                {
                  "slug": "goblin-ear",
                  "qty": 2
                },
                {
                  "slug": "health-potion",
                  "qty": 1
                }
              ],
              "xp": 18
            }
          },
          "failure": {
            "text": "The goblin decides you're boring and packs up in a huff. \"No deal! Bad trader!\"",
            "rewards": {
              "xp": 8
            }
          }
        },
        {
          "label": "Intimidate it into giving you its wares",
          "check": {
            "stat": "str",
            "dc": 12
          },
          "success": {
            "text": "The goblin squeaks in terror and shoves a pouch of gold at you before fleeing.",
            "rewards": {
              "gold": 35,
              "xp": 15
            }
          },
          "failure": {
            "text": "The goblin whistles sharply and you hear rumbling deeper in the cave. Time to leave.",
            "rewards": {
              "xp": 5,
              "damage": 10
            }
          }
        }
      ]
    },
    {
      "slug": "cave-inscription",
      "name": "Ancient Inscription",
      "type": "discovery",
      "rarity": "common",
      "icon": "\ud83d\udcdc",
      "text": "Strange runes are carved deep into the cave wall, glowing faintly with residual magic. They seem to be instructions or warnings.",
      "choices": [
        {
          "label": "Decipher the runes",
          "check": {
            "stat": "int",
            "dc": 11
          },
          "success": {
            "text": "The runes describe an ancient ward. Understanding them fills your mind with arcane insight.",
            "rewards": {
              "xp": 30
            }
          },
          "failure": {
            "text": "The symbols blur together. You copy a few for later study, but learn nothing now.",
            "rewards": {
              "xp": 10
            }
          }
        },
        {
          "label": "Touch the glowing runes",
          "check": {
            "stat": "con",
            "dc": 10
          },
          "success": {
            "text": "Energy crackles through you \u2014 painful but invigorating. You feel tougher.",
            "rewards": {
              "healPct": 20,
              "xp": 15
            }
          },
          "failure": {
            "text": "A jolt of energy throws you backward. Your hand tingles painfully.",
            "rewards": {
              "xp": 5,
              "damage": 12
            }
          }
        }
      ]
    },
    {
      "slug": "cave-in",
      "name": "Unstable Passage",
      "type": "environmental",
      "rarity": "common",
      "icon": "\ud83e\udea8",
      "text": "The tunnel narrows ahead and small rocks trickle from the ceiling. It could collapse at any moment, but there may be something beyond.",
      "choices": [
        {
          "label": "Sprint through before it collapses",
          "check": {
            "stat": "dex",
            "dc": 11
          },
          "success": {
            "text": "You dash through as rocks crash behind you! Beyond, you find a small cache of ore.",
            "rewards": {
              "items": [
                {
                  "slug": "iron-ore",
                  "qty": 3
                }
              ],
              "xp": 20
            }
          },
          "failure": {
            "text": "Rocks clip your shoulder as you barely make it through. Painful, but you survived.",
            "rewards": {
              "xp": 10,
              "damage": 15
            }
          }
        },
        {
          "label": "Shore up the ceiling carefully",
          "check": {
            "stat": "str",
            "dc": 12
          },
          "success": {
            "text": "Using loose timbers, you brace the passage and explore safely. Bone dust lines the far chamber.",
            "rewards": {
              "items": [
                {
                  "slug": "bone-dust",
                  "qty": 2
                }
              ],
              "xp": 18
            }
          },
          "failure": {
            "text": "The timber snaps and debris rains down. You retreat just in time.",
            "rewards": {
              "xp": 8
            }
          }
        }
      ]
    },
