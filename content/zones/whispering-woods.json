  "events": [
    {
      "slug": "lost-herbalist",
      "name": "Lost Herbalist",
      "type": "npc",
      "rarity": "common",
      "icon": "\ud83e\uddd9",
      "text": "A frail herbalist clutches a torn map, clearly lost among the ancient trees. She offers to share her knowledge if you can guide her back to the path.",
      "choices": [
        {
          "label": "Guide her using your knowledge of the woods",
          "check": {
            "stat": "wis",
            "dc": 10
          },
          "success": {
            "text": "Your keen sense of direction leads her safely to the road. Grateful, she hands you a bundle of healing herbs.",
            "rewards": {
              "items": [
                {
                  "slug": "healing-herb",
                  "qty": 3
                }
              ],
              "xp": 15
            }
          },
          "failure": {
            "text": "You wander in circles before she finds her own way. She leaves with a pitying smile.",
            "rewards": {
              "xp": 5
            }
          }
        },
        {
          "label": "Demand payment for your help",
          "check": {
            "stat": "cha",
            "dc": 12
          },
          "success": {
            "text": "She reluctantly parts with some coins and a rare moonpetal she was gathering.",
            "rewards": {
              "gold": 25,
              "items": [
                {
                  "slug": "moonpetal",
                  "qty": 1
                }
              ],
              "xp": 10
            }
          },
          "failure": {
            "text": "She scoffs and hobbles off on her own. You feel a twinge of regret.",
            "rewards": {
              "xp": 5
            }
          }
        },
        {
          "label": "Ignore her and continue exploring",
          "auto": true,
          "success": {
            "text": "You push on. The woods swallow her cries behind you.",
            "rewards": {
              "xp": 3
            }
          }
        }
      ]
    },
    {
      "slug": "trapped-chest-woods",
      "name": "Overgrown Chest",
      "type": "discovery",
      "rarity": "uncommon",
      "icon": "\ud83d\udce6",
      "text": "Beneath a tangle of roots, you spot a weathered chest. Faint scratches on the lock suggest a trap mechanism.",
      "choices": [
        {
          "label": "Disarm the trap carefully",
          "check": {
            "stat": "dex",
            "dc": 11
          },
          "success": {
            "text": "Click! The trap disengages. Inside: a small pouch of gold and a wolf pelt.",
            "rewards": {
              "gold": 20,
              "items": [
                {
                  "slug": "wolf-pelt",
                  "qty": 2
                }
              ],
              "xp": 18
            }
          },
          "failure": {
            "text": "SNAP! A dart catches your arm. You wrench the chest open but find little inside.",
            "rewards": {
              "xp": 8,
              "damage": 12
            }
          }
        },
        {
          "label": "Smash it open with brute force",
          "check": {
            "stat": "str",
            "dc": 10
          },
          "success": {
            "text": "The chest splinters open. Some gold spills out among the splinters.",
            "rewards": {
              "gold": 15,
              "xp": 12
            }
          },
          "failure": {
            "text": "The chest holds firm and the trap catches you square in the chest.",
            "rewards": {
              "xp": 5,
              "damage": 18
            }
          }
        },
        {
          "label": "Leave it alone",
          "auto": true,
          "success": {
            "text": "Wisdom sometimes means knowing when to walk away.",
            "rewards": {
              "xp": 3
            }
          }
        }
      ]
    },
