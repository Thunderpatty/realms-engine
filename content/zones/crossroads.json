  "events": [
    {
      "slug": "fortune-teller",
      "name": "Wandering Seer",
      "type": "npc",
      "rarity": "uncommon",
      "icon": "\ud83d\udd2e",
      "text": "A hooded figure sits at the crossroads, cards spread on a tattered cloth. \"Your fate hangs in the balance, traveler. Shall I read it?\"",
      "choices": [
        {
          "label": "Accept the reading",
          "check": {
            "stat": "cha",
            "dc": 10
          },
          "success": {
            "text": "The cards glow faintly. \"Fortune smiles on you today.\" You feel a surge of vitality.",
            "rewards": {
              "healPct": 25,
              "manaPct": 50,
              "xp": 25
            }
          },
          "failure": {
            "text": "The seer frowns. \"Dark clouds gather...\" A chill runs through you but nothing happens.",
            "rewards": {
              "xp": 10
            }
          }
        },
        {
          "label": "Challenge the seer's magic with your intellect",
          "check": {
            "stat": "int",
            "dc": 14
          },
          "success": {
            "text": "You identify the arcane symbols on the cards. Impressed, the seer shares a secret technique.",
            "rewards": {
              "xp": 40
            }
          },
          "failure": {
            "text": "The symbols defy your analysis. \"Not everything is understood through study, child.\"",
            "rewards": {
              "xp": 10
            }
          }
        },
        {
          "label": "Walk away",
          "auto": true,
          "success": {
            "text": "\"We all meet our fate eventually,\" the seer calls after you.",
            "rewards": {
              "xp": 3
            }
          }
        }
      ]
    },
    {
      "slug": "broken-wagon",
      "name": "Abandoned Wagon",
      "type": "discovery",
      "rarity": "common",
      "icon": "\ud83d\uded2",
      "text": "An overturned wagon lies in a ditch, its contents scattered. Claw marks score the wood \u2014 something attacked the driver.",
      "choices": [
        {
          "label": "Salvage what you can from the wreckage",
          "check": {
            "stat": "str",
            "dc": 9
          },
          "success": {
            "text": "You right some crates and find intact supplies among the debris.",
            "rewards": {
              "gold": 20,
              "items": [
                {
                  "slug": "linen-cloth",
                  "qty": 2
                }
              ],
              "xp": 15
            }
          },
          "failure": {
            "text": "The wreckage shifts and pins your hand briefly. You pull free with just a bruise.",
            "rewards": {
              "xp": 5,
              "damage": 8
            }
          }
        },
        {
          "label": "Track what attacked the wagon",
          "check": {
            "stat": "wis",
            "dc": 12
          },
          "success": {
            "text": "The tracks lead to a creature's stash \u2014 gold and materials piled in a hollow tree.",
            "rewards": {
              "gold": 30,
              "items": [
                {
                  "slug": "boar-tusk",
                  "qty": 2
                }
              ],
              "xp": 20
            }
          },
          "failure": {
            "text": "The tracks circle back confusingly. Whatever did this is long gone.",
            "rewards": {
              "xp": 8
            }
          }
        }
      ]
    },
    {
      "slug": "traveling-monk",
      "name": "Pilgrim Monk",
      "type": "npc",
      "rarity": "common",
      "icon": "\ud83d\ude4f",
      "text": "A barefoot monk walks the crossroads, chanting softly. He pauses and bows. \"May I share a blessing, friend?\"",
      "choices": [
        {
          "label": "Accept his blessing",
          "check": {
            "stat": "wis",
            "dc": 8
          },
          "success": {
            "text": "Warmth flows through you as the monk traces a symbol in the air. Your wounds ease.",
            "rewards": {
              "healPct": 35,
              "xp": 15
            }
          },
          "failure": {
            "text": "The monk blesses you, but you feel nothing different. \"Faith takes time,\" he says gently.",
            "rewards": {
              "xp": 8
            }
          }
        },
        {
          "label": "Ask him about the roads ahead",
          "check": {
            "stat": "cha",
            "dc": 10
          },
          "success": {
            "text": "He describes hidden paths and dangers. The knowledge will serve you well.",
            "rewards": {
              "xp": 25
            }
          },
          "failure": {
            "text": "\"I am but a simple pilgrim. The roads reveal themselves to those who walk them.\"",
            "rewards": {
              "xp": 8
            }
          }
        }
      ]
    },
