  "events": [
    {
      "slug": "ghostly-vision",
      "name": "Spectral Echo",
      "type": "shrine",
      "rarity": "uncommon",
      "icon": "\ud83d\udc7b",
      "text": "A translucent figure materializes before you \u2014 the ghost of a priest who once tended this shrine. \"Seeker... will you hear my final prayer?\"",
      "choices": [
        {
          "label": "Listen to the ghost's prayer",
          "check": {
            "stat": "wis",
            "dc": 11
          },
          "success": {
            "text": "The ghost recounts a blessing. As the words echo, you feel divine energy restore you.",
            "rewards": {
              "healPct": 50,
              "manaPct": 30,
              "xp": 25
            }
          },
          "failure": {
            "text": "The ghost's words fade to whispers you cannot understand. It dissolves with a sigh.",
            "rewards": {
              "xp": 10
            }
          }
        },
        {
          "label": "Ask the ghost about hidden treasures",
          "check": {
            "stat": "cha",
            "dc": 13
          },
          "success": {
            "text": "\"Behind the altar... the third stone...\" The ghost fades. You find a hidden compartment with holy shards.",
            "rewards": {
              "items": [
                {
                  "slug": "holy-shard",
                  "qty": 2
                }
              ],
              "gold": 25,
              "xp": 20
            }
          },
          "failure": {
            "text": "The ghost scowls. \"Greed defiles this place.\" It vanishes in a cold wind.",
            "rewards": {
              "xp": 5,
              "damage": 10
            }
          }
        }
      ]
    },
    {
      "slug": "crumbling-floor",
      "name": "Crumbling Floor",
      "type": "environmental",
      "rarity": "common",
      "icon": "\u26a0",
      "text": "The floor ahead is fractured with deep cracks. Something glints in the gap below, but one wrong step could send you tumbling.",
      "choices": [
        {
          "label": "Carefully edge along the wall",
          "check": {
            "stat": "dex",
            "dc": 10
          },
          "success": {
            "text": "You traverse the gap safely and scoop up the wraith essence that had pooled below.",
            "rewards": {
              "items": [
                {
                  "slug": "wraith-essence",
                  "qty": 2
                }
              ],
              "xp": 18
            }
          },
          "failure": {
            "text": "A section gives way and you drop several feet before catching yourself. Bruised but alive.",
            "rewards": {
              "xp": 8,
              "damage": 14
            }
          }
        },
        {
          "label": "Jump across the widest gap",
          "check": {
            "stat": "str",
            "dc": 11
          },
          "success": {
            "text": "You clear the gap with room to spare and land near a stash of bone dust.",
            "rewards": {
              "items": [
                {
                  "slug": "bone-dust",
                  "qty": 2
                }
              ],
              "xp": 15
            }
          },
          "failure": {
            "text": "You barely make it, slamming into the far edge. Your ribs ache.",
            "rewards": {
              "xp": 8,
              "damage": 12
            }
          }
        }
      ]
    },
    {
      "slug": "hidden-chamber",
      "name": "Hidden Chamber",
      "type": "discovery",
      "rarity": "rare",
      "icon": "\ud83d\udeaa",
      "text": "A concealed door behind a fallen statue reveals a chamber untouched for centuries. Dust motes dance in the stale air.",
      "choices": [
        {
          "label": "Search the chamber thoroughly",
          "check": {
            "stat": "int",
            "dc": 12
          },
          "success": {
            "text": "Ancient texts and preserved holy relics fill the shelves. You take what you can carry.",
            "rewards": {
              "items": [
                {
                  "slug": "holy-shard",
                  "qty": 2
                }
              ],
              "gold": 30,
              "xp": 30
            }
          },
          "failure": {
            "text": "You trigger a ward that seals the door behind you momentarily. Panic sets in before it reopens.",
            "rewards": {
              "xp": 10
            }
          }
        },
        {
          "label": "Check for traps before entering",
          "check": {
            "stat": "dex",
            "dc": 11
          },
          "success": {
            "text": "You disarm a tripwire and safely loot the chamber. Gold and wraith essence reward your caution.",
            "rewards": {
              "gold": 35,
              "items": [
                {
                  "slug": "wraith-essence",
                  "qty": 1
                }
              ],
              "xp": 25
            }
          },
          "failure": {
            "text": "You miss a pressure plate and a dart nicks your arm. At least the chamber is now safe to explore... mostly.",
            "rewards": {
              "gold": 15,
              "xp": 12,
              "damage": 10
            }
          }
        }
      ]
    },
