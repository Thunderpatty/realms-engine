# ═══════════════════════════════════════════
# Realms Engine — Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════

# Server
PORT=8080
HOST=0.0.0.0

# PostgreSQL Database
# Use either the discrete vars below OR DATABASE_URL (DATABASE_URL takes precedence)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=realms
POSTGRES_PASSWORD=change-me-to-something-secure
POSTGRES_DB=realms_game
# DATABASE_URL=postgres://user:pass@host:5432/db   # alternative connection string
# DATABASE_SSL=true                                 # set when connecting to a hosted PG that requires TLS

# Session
SESSION_SECRET=           # Leave blank to auto-generate
SESSION_NAME=realms_sid   # Cookie name (change if running multiple instances)

# Rate Limiting (requests per 15-minute window)
RATE_LIMIT_AUTH=20
RATE_LIMIT_GAME=300
RATE_LIMIT_POLL=600

# Tests (only used by tests/, not the server)
# TEST_URL=http://127.0.0.1:8080
